# Copy to .env for local dev (never commit the real .env).
# On Vercel these are set via the dashboard instead.

# Neon Postgres connection string (Storage -> Neon Postgres sets this on Vercel)
DATABASE_URL=

# Vercel Blob token (Storage -> Blob sets this on Vercel)
BLOB_READ_WRITE_TOKEN=

# Long random string used to sign the login cookie.
# A freshly generated one you can use:
SESSION_SECRET=9fbc183e6ed7a84762470f35b60287950268602c6a640f6c5de700dacb0a5934

# Password for the first admin account, used once by: npm run setup-db
SEED_ADMIN_PASSWORD=change-me-first-login
