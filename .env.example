# Copy to .env for local dev (never commit the real .env).
# On Vercel these are set via the dashboard instead.

# Neon Postgres connection string (Storage -> Neon Postgres sets this on Vercel)
DATABASE_URL=

# Vercel Blob token (Storage -> Blob sets this on Vercel)
BLOB_READ_WRITE_TOKEN=

# Long random string used to sign the login cookie.
# A freshly generated one you can use:
SESSION_SECRET=9fbc183e6ed7a84762470f35b60287950268602c6a640f6c5de700dacb0a5934

# Password for the first admin account, used once by: npm run setup-db
SEED_ADMIN_PASSWORD=change-me-first-login

# --- Email (Resend) --------------------------------------------------------
# Powers password-reset links and workflow notifications (submissions to
# approve, rejections, and the daily reminder). If these are unset, the portal
# still runs but silently skips sending email (logged as a warning).
# API key from https://resend.com (Dashboard -> API Keys)
RESEND_API_KEY=
# Verified sender. Must use a domain you've verified in Resend.
EMAIL_FROM=Reimbursement Portal <noreply@yourdomain.com>
# Public base URL of the portal, used to build links inside emails.
# No trailing slash, e.g. https://reimbursement.example.com
APP_URL=

# --- Daily reminder cron ---------------------------------------------------
# Shared secret protecting GET /api/cron/reminders. Vercel Cron automatically
# sends this as "Authorization: Bearer <CRON_SECRET>". Set it to a long random
# string. If unset, the endpoint is unprotected — always set it in production.
CRON_SECRET=
